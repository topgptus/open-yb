{
  "manifest_version": 3,
  "name": "Open YB",
  "description": "在 Chrome 中打开腾讯元宝微信分享页，也可把当前网页保存为 Markdown 收藏。",
  "version": "0.3.0",
  "homepage_url": "https://github.com/topgptus/open-yb",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Open YB",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "permissions": [
    "activeTab",
    "declarativeNetRequestWithHostAccess",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://yb.tencent.com/wx/ct/*",
    "https://yuanbao.tencent.com/wx/ct/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://yb.tencent.com/wx/ct/*",
        "https://yuanbao.tencent.com/wx/ct/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
